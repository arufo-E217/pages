                <div class="hero-slide" style={`background-image: url('${slide2.src}');`}></div>
                <div class="hero-slide" style={`background-image: url('${slide3.src}');`}></div>
                <div class="hero-slide" style={`background-image: url('${slide4.src}');`}></div>
            </div>

            <div class="heroOverlay"></div>
            <div class="heroContent">
                <h2>Aruphy.K</h2>
                <p>-Game developer / High school student-</p>
            </div>
            <div class="scroll-down-indicator">
                <span>↓ scroll</span>
            </div>
        </section>

        <!-- 中ページ -->
        <div class="middle-page-container">
            
            <div class="welcome-msg-wrapper line-reveal-trigger">
                <p class="welcome-msg">ようこそおいでなすった ゆっくりしていくがよい！</p>
            </div>
            
            <div class="asymmetric-cards-wrapper">
                <div class="asymmetric-card card-left-round fade-slide-left">
                    <div class="card-inner-content">
                        <div class="card-icon">🍡</div>
                        <div class="card-text">
                            <h3>About Me</h3>
                            <p>名前 : あるふぉーと！
                                <br>誕生日 : 2008/11/18
                                <br>趣味 : ゲーム作り
                                <br>生粋の気分屋
                            </p>
                        </div>
                    </div>
                </div>

                <div class="asymmetric-card card-right-round fade-slide-right">
                    <div class="card-inner-content">
                        <div class="card-icon">🏆</div>
                        <div class="card-text">
                            <h3>Achievements</h3>
                            <p>
                                <strong>Programming</strong>
                                <br>C#, Python, JavaScript, HTML/CSS
                                <br>AtCoder (<a href="https://atcoder.jp/users/arufo_E217" target="_blank" rel="noopener">arufo_E217</a>) - Algorithm🟤 Heuristic🟤
                            </p>
                            <p style="margin-top: 15px;">
                                <strong>Unity</strong>
                                <br>・Rhythm Game
                                <br>・<a href="https://unityroom.com/games/function_love_equal_undefined" target="_blank" rel="noopener">visual novel</a>
                                <br>・Shooting Games
                            </p>
                            <p style="margin-top: 15px;">
                                <strong>Games</strong>
                                <br>CHUNITHM -RATING max 16.42
                                <br>maimai   -RATING max 12634
                                <br>オンゲキ  -RATING max 17.644
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 新着の日記セクション（Achievementsの下） -->
            <div class="recent-diaries-section fade-up">
                <h3>Recent Diaries / <a href={`${import.meta.env.BASE_URL}/diary`} style="color: var(--accent-color); text-decoration: underline;">→ View All</a></h3>
                <div class="diary-cards-container">
                    {recentDiaries.map((post) => (
                        <a href={`${import.meta.env.BASE_URL}/diary/${post.id}`} class="diary-card-sharp">
                            <div class="diary-card-content">
                                <!-- 日付と時刻を表示 -->
