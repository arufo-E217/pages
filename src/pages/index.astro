---
import { getCollection, render } from 'astro:content';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

import '../styles/style.css';

import slide1 from '../assets/images/slide1.png';
import slide2 from '../assets/images/slide2.png';
import slide3 from '../assets/images/slide3.png';
import slide4 from '../assets/images/slide4.png';

const allDiaries = await getCollection('diaries');

// --- サーバー側で安全にカウンターAPIを叩き、累計と日計を取得する処理 ---
let visitorCount = 0;
let todayCount = 0;

try {
    const response = await fetch('https://api.counterapi.dev/v2/s-team-43-4815/arufositesvisiter/up', {
        headers: {
            'Authorization': `Bearer ${import.meta.env.COUNTER_API_KEY}`
        }
    });
    const result = await response.json();
    
    // 累計（up_count）を取得
    visitorCount = result.data?.up_count ?? 0;

    // もし /up のレスポンスに stats が含まれている場合はそこから今日の日付の数値を取得
    // （含まれていない場合の保険として /stats も併用できるようにしています）
    if (result.data?.stats?.today?.up !== undefined) {
        todayCount = result.data.stats.today.up;
    } else {
        // 万が一 /up 側に stats がない場合は別途 /stats を叩きに行く安全設計
        const statsResponse = await fetch('https://api.counterapi.dev/v2/s-team-43-4815/arufositesvisiter/stats', {
            headers: {
                'Authorization': `Bearer ${import.meta.env.COUNTER_API_KEY}`
            }
        });
        const statsResult = await statsResponse.json();
        todayCount = statsResult.data?.stats?.today?.up ?? 0;
    }
} catch (error) {
    console.error('カウンターの取得に失敗しました:', error);
}

// 24時以降（例: 25:34）の時間を考慮して正しくソートするための関数
function parseCustomDate(dateStr: string) {
    if (!dateStr) return 0;
    
    const normalized = dateStr.replace('T', ' ');
    const [datePart, timePart] = normalized.split(' ');
    
    if (!datePart || !timePart) {
        return new Date(dateStr).getTime() || 0;
    }

    const [year, month, day] = datePart.split('-').map(Number);
    const [hour, minute, second = 0] = timePart.split(':').map(Number);

    const baseDate = new Date(year, month - 1, day);
    baseDate.setHours(hour, minute, second);

    return baseDate.getTime();
}

// 新しい順（降順）に並び替え
const recentDiaries = allDiaries
  .sort((a, b) => parseCustomDate(String(b.data.date)) - parseCustomDate(String(a.data.date)))
  .slice(0, 5);

// 文字数制限をつけて「...」にする関数
function createExcerpt(body: string = '', maxLength: number = 30) {
  if (!body) return '';
  const cleaned = body
    .replace(/<img[^>]*>/gi, '[画像]')
    .replace(/<br\s*[\/]?>/gi, '')
    .replace(/<[^>]*>?/gm, '')
    .replace(/[\r\n]+/g, '')
    .trim();
  
  if (cleaned.length > maxLength) {
    return cleaned.substring(0, maxLength) + '...';
  }
  return cleaned;
}

// 24時以降（25:30など）の時刻も崩さずに「YYYY/MM/DD HH:mm」形式にする関数
function formatDateTime(dateString: string) {
    if (!dateString) return '';
    const normalized = dateString.replace('T', ' ');
    const [datePart, timePart] = normalized.split(' ');
    
    if (!datePart || !timePart) {
        const d = new Date(dateString);
        if (isNaN(d.getTime())) return dateString;
        const year = d.getFullYear();
        const month = String(d.getMonth() + 1).padStart(2, '0');
        const day = String(d.getDate()).padStart(2, '0');
        const hours = String(d.getHours()).padStart(2, '0');
        const minutes = String(d.getMinutes()).padStart(2, '0');
        return `${year}/${month}/${day} ${hours}:${minutes}`;
    }

    const [year, month, day] = datePart.split('-');
    const [hour, minute] = timePart.split(':');

    if (!year || !month || !day || !hour || !minute) {
        return dateString;
    }

    return `${year}/${month}/${day} ${hour}:${minute}`;
}
---
<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>あるふぉーとのゲーム置き場 - Top</title>
    <!-- Google Fonts: Zen Maru Gothic -->
