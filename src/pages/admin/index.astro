---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/style.css';
---

<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>日記管理画面 - あるふぉーとのゲーム置き場</title>
    <link href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        .admin-form {
            display: flex;
            flex-direction: column;
            gap: 20px;
            background: #fff;
            padding: 40px;
            border-radius: 30px;
            box-sizing: border-box;
            width: 100%;
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        }
        .form-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .form-group label {
            font-weight: 700;
            color: var(--accent-color, #ff8fab);
            font-size: 0.95rem;
        }
        .form-group input, .form-group textarea {
            padding: 12px 16px;
            border: 2px solid #eee;
            border-radius: 12px;
            font-family: 'Zen Maru Gothic', sans-serif;
            font-size: 1rem;
            outline: none;
            transition: border-color 0.2s;
            box-sizing: border-box;
            width: 100%;
        }
        .form-group input:focus, .form-group textarea:focus {
            border-color: var(--accent-color, #ff8fab);
        }
        .submit-btn {
            background-color: var(--accent-color, #ff8fab);
            color: white;
            border: none;
            padding: 14px;
            border-radius: 15px;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: opacity 0.2s;
            font-family: 'Zen Maru Gothic', sans-serif;
        }
        .submit-btn:hover {
            opacity: 0.9;
        }
        .image-upload-bar {
            display: flex;
            align-items: center;
            gap: 10px;
            background: #fff5f7;
            padding: 12px 16px;
            border-radius: 12px;
            border: 2px dashed #ff8fab;
        }
        .image-upload-bar input[type="file"] {
            display: none;
        }
        .upload-btn-label {
            background-color: white;
            color: var(--accent-color, #ff8fab);
            border: 2px solid var(--accent-color, #ff8fab);
            padding: 8px 16px;
            border-radius: 10px;
            font-weight: 700;
            font-size: 0.9rem;
            cursor: pointer;
            transition: all 0.2s;
        }
        .upload-btn-label:hover {
            background-color: var(--accent-color, #ff8fab);
            color: white;
        }
        #image-msg {
            font-size: 0.85rem;
            color: #666;
            font-weight: 700;
        }
        #result-msg {
            font-weight: 700;
            text-align: center;
            font-size: 0.95rem;
        }
        .settings-box {
            background: #fff5f7;
            padding: 20px;
            border-radius: 20px;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>

    <Header/>

    <main>
        <div class="middle-page-container" style="padding-top: 140px; max-width: 800px; margin: 0 auto; padding-left: 20px; padding-right: 20px; padding-bottom: 60px;">
            <div class="welcome-msg-wrapper" style="margin-bottom: 20px;">
                <p class="welcome-msg" style="opacity: 1; transform: translateY(0);">-日記管理画面-<br>日記マークダウンファイル生成・投稿</p>
            </div>

            <form id="diaryForm" class="admin-form">
                
                <!-- GitHub設定エリア -->
                <div class="settings-box">
                    <h3 style="font-size: 1rem; color: #333; margin-bottom: 12px;">⚙️ GitHub連携設定（初回のみ）</h3>
                    <div style="display: flex; flex-direction: column; gap: 12px;">
                        <div class="form-group">
                            <label for="ghToken">Personal Access Token (GitHub)</label>
                            <input type="password" id="ghToken" required placeholder="ghp_xxxxxxxxxxxx">
                        </div>
                        <div style="display: flex; gap: 10px;">
                            <div class="form-group" style="flex: 1;">
                                <label for="ghOwner">GitHub ユーザー名</label>
                                <input type="text" id="ghOwner" required placeholder="例: aruphy">
                            </div>
                            <div class="form-group" style="flex: 1;">
                                <label for="ghRepo">リポジトリ名</label>
                                <input type="text" id="ghRepo" required placeholder="例: aruphy-site">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 記事入力エリア -->
                <div class="form-group">
                    <label for="title">タイトル</label>
                    <input type="text" id="title" required placeholder="例：今日はボスを倒した！">
                </div>

                <div class="form-group">
                    <label for="date">日時</label>
                    <input type="datetime-local" id="date" required>
                </div>

                <div class="form-group">
                    <label for="filename">ファイル名（半角英数字）</label>
                    <input type="text" id="filename" required placeholder="例：20260722221500">
                    <span style="font-size: 0.8rem; color: #888;">※自動で数字のみの日時が入ります（.mdは自動でつきます）</span>
                </div>

                <div class="form-group">
                    <label>本文 & 画像挿入</label>
                    <div class="image-upload-bar">
                        <label for="imageFile" class="upload-btn-label">🖼️ 画像を選択してアップロード</label>
                        <input type="file" id="imageFile" accept="image/*">
                        <span id="image-msg">画像を選ぶと自動でGitHubに保存され、本文に挿入されます</span>
                    </div>
                    <textarea id="content" rows="10" placeholder="ここに日記の本文を書くよ..."></textarea>
                </div>

                <button type="submit" class="submit-btn">✨ GitHubに日記をCommitする</button>
                <p id="result-msg"></p>
            </form>
        </div>
    </main>

    <Footer/>

    <script>
        const form = document.getElementById('diaryForm') as HTMLFormElement;
        const resultMsg = document.getElementById('result-msg') as HTMLElement;
        const imageFileInput = document.getElementById('imageFile') as HTMLInputElement;
        const imageMsg = document.getElementById('image-msg') as HTMLElement;
        const contentArea = document.getElementById('content') as HTMLTextAreaElement;

        // スマホのブラウザ（LocalStorage）から前回のGitHub設定を自動復元する
        const savedToken = localStorage.getItem('gh_token');
        const savedOwner = localStorage.getItem('gh_owner');
        const savedRepo = localStorage.getItem('gh_repo');

        if (savedToken) (document.getElementById('ghToken') as HTMLInputElement).value = savedToken;
        if (savedOwner) (document.getElementById('ghOwner') as HTMLInputElement).value = savedOwner;
        if (savedRepo) (document.getElementById('ghRepo') as HTMLInputElement).value = savedRepo;

        // 端末のローカル時間を正確に取得してフォームの初期値にセットする関数
        const setLocalDateTimeValues = () => {
            const now = new Date();
            const pad = (n: number) => String(n).padStart(2, '0');
            
            const year = now.getFullYear();
            const month = pad(now.getMonth() + 1);
            const day = pad(now.getDate());
            const hours = pad(now.getHours());
            const minutes = pad(now.getMinutes());
            const seconds = pad(now.getSeconds());

            const datetimeLocalVal = `${year}-${month}-${day}T${hours}:${minutes}`;
            const dateInput = document.getElementById('date') as HTMLInputElement;
            if (dateInput && !dateInput.value) {
                dateInput.value = datetimeLocalVal;
            }

            const filenameVal = `${year}${month}${day}${hours}${minutes}${seconds}`;
            const filenameInput = document.getElementById('filename') as HTMLInputElement;
            if (filenameInput && !filenameInput.value) {
                filenameInput.value = filenameVal;
            }
        };

        setLocalDateTimeValues();

        // 画像選択時の処理（即座にGitHubにアップロードしてMarkdownを挿入）
        imageFileInput.addEventListener('change', async () => {
            const file = imageFileInput.files?.[0];
            if (!file) return;

            const token = (document.getElementById('ghToken') as HTMLInputElement).value.trim();
            const owner = (document.getElementById('ghOwner') as HTMLInputElement).value.trim();
            const repo = (document.getElementById('ghRepo') as HTMLInputElement).value.trim();

            if (!token || !owner || !repo) {
                alert('先に上部の「GitHub連携設定（トークン、ユーザー名、リポジトリ名）」を入力してください！');
                imageFileInput.value = '';
                return;
            }

            imageMsg.style.color = '#ff8fab';
            imageMsg.textContent = '🚀 画像をGitHubへアップロード中...';

            try {
                // ファイル名をユニークにする（例: 20260722235600_filename.jpg）
                const now = new Date();
                const pad = (n: number) => String(n).padStart(2, '0');
                const timestamp = `${now.getFullYear()}${pad(now.getMonth() + 1)}${pad(now.getDate())}${pad(now.getHours())}${pad(now.getMinutes())}${pad(now.getSeconds())}`;
                const safeImgName = `${timestamp}_${file.name.replace(/[^a-zA-Z0-9_.-]/g, '_')}`;
                const imagePath = `public/images/diaries/${safeImgName}`;

                // 画像ファイルをBase64に変換
                const reader = new FileReader();
                reader.readAsDataURL(file);
                reader.onload = async () => {
                    const base64Data = (reader.result as string).split(',')[1];

                    const res = await fetch(`https://api.github.com/repos/${owner}/${repo}/contents/${imagePath}`, {
                        method: 'PUT',
                        headers: {
                            'Authorization': `Bearer ${token}`,
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({
                            message: `Upload image: ${safeImgName}`,
                            content: base64Data,
                            branch: 'main'
                        })
                    });

                    if (res.ok) {
                        imageMsg.style.color = '#2e7d32';
                        imageMsg.textContent = '✅ 画像のアップロード成功！本文に挿入しました';

                        // Markdownタグを本文に挿入（Astroではpublicフォルダ内のファイルは /images/diaries/... で参照可能）
                        const markdownImageTag = `\n![](/images/diaries/${safeImgName})\n`;
                        const startPos = contentArea.selectionStart;
                        const endPos = contentArea.selectionEnd;
                        const text = contentArea.value;

                        contentArea.value = text.substring(0, startPos) + markdownImageTag + text.substring(endPos);
                        contentArea.focus();
                        imageFileInput.value = ''; // リセット
                    } else {
                        const err = await res.json();
                        imageMsg.style.color = '#c62828';
                        imageMsg.textContent = `❌ アップロード失敗: ${err.message || 'エラー'}`;
                    }
                };
            } catch (e) {
                imageMsg.style.color = '#c62828';
                imageMsg.textContent = '❌ 画像の読み込みに失敗しました';
            }
        });

        // 記事全体の送信処理
        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            const token = (document.getElementById('ghToken') as HTMLInputElement).value.trim();
            const owner = (document.getElementById('ghOwner') as HTMLInputElement).value.trim();
            const repo = (document.getElementById('ghRepo') as HTMLInputElement).value.trim();
            
            const title = (document.getElementById('title') as HTMLInputElement).value;
            const date = (document.getElementById('date') as HTMLInputElement).value;
            const filename = (document.getElementById('filename') as HTMLInputElement).value.trim();
            const content = (document.getElementById('content') as HTMLTextAreaElement).value;

            localStorage.setItem('gh_token', token);
            localStorage.setItem('gh_owner', owner);
            localStorage.setItem('gh_repo', repo);

            const safeFilename = filename.endsWith('.md') ? filename : `${filename}.md`;
            const path = `src/content/diaries/${safeFilename}`;

            const mdContent = `---
title: "${title}"
date: "${date}"
---

${content}
`;

            const contentEncoded = btoa(unescape(encodeURIComponent(mdContent)));

            resultMsg.style.color = '#666';
            resultMsg.textContent = '🚀 GitHubへ送信中...';

            try {
                const response = await fetch(`https://api.github.com/repos/${owner}/${repo}/contents/${path}`, {
                    method: 'PUT',
                    headers: {
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        message: `Add diary: ${title}`,
                        content: contentEncoded,
                        branch: 'main'
                    })
                });

                if (response.ok) {
                    resultMsg.style.color = '#2e7d32';
                    resultMsg.textContent = '🎉 成功！GitHubへのコミットが完了しました。数分後にサイトが自動更新されます！';
                    
                    const now = new Date();
                    const pad = (n: number) => String(n).padStart(2, '0');
                    const newFilenameVal = `${now.getFullYear()}${pad(now.getMonth() + 1)}${pad(now.getDate())}${pad(now.getHours())}${pad(now.getMinutes())}${pad(now.getSeconds())}`;
                    
                    (document.getElementById('title') as HTMLInputElement).value = '';
                    (document.getElementById('filename') as HTMLInputElement).value = newFilenameVal;
                    (document.getElementById('content') as HTMLTextAreaElement).value = '';
                } else {
                    const errData = await response.json();
                    resultMsg.style.color = '#c62828';
                    resultMsg.textContent = `❌ エラー: ${errData.message || '送信に失敗しました'}`;
                }
            } catch (err) {
                resultMsg.style.color = '#c62828';
                resultMsg.textContent = '❌ 通信エラーが発生しました。';
            }
        });
    </script>
</body>
</html>