---

<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ゲーム一覧 - あるふぉーとのゲーム置き場</title>
    <link href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        /* ゲーム一覧ページ専用のスタイル調整 */
        .games-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
            margin-top: 30px;
        }

        .game-card {
            background-color: var(--card-bg, #ffffff);
            border: 2px solid var(--border-color, #fce4ec);
            border-radius: 24px;
            padding: 24px;
            box-shadow: 0 4px 15px rgba(255, 143, 171, 0.06);
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            text-decoration: none;
        }

        .game-card:hover {
            transform: translateY(-4px);
            border-color: var(--accent-color, #ff8fab);
            box-shadow: 0 8px 25px rgba(255, 143, 171, 0.2);
        }

        .game-card-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 12px;
        }

        .game-icon {
            font-size: 1.8rem;
            background: #fff0f3;
            width: 50px;
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .game-title {
            font-size: 1.05rem;
            font-weight: 700;
            color: var(--accent-color, #ff8fab);
            margin: 0;
            line-height: 1.4;
        }

        .game-desc {
            font-size: 0.85rem;
            color: #7d6b70;
            margin: 0 0 15px 0;
            line-height: 1.5;
        }

        .game-link-text {
            font-size: 0.8rem;
            font-weight: 700;
            color: var(--accent-color, #ff8fab);
            align-self: flex-end;
            transition: var(--transition);
        }

        .game-card:hover .game-link-text {
            text-decoration: underline;
        }

        .welcome-message-box {
            text-align: center;
            margin-bottom: 40px;
        }
    </style>
</head>
<body>

    <!-- 共通ヘッダー -->
    <Header />

    <main>
        <div class="middle-page-container" style="padding-top: 140px;">
            
            <!-- ヒーロー風メッセージ -->
            <div class="welcome-message-box">
                <div class="welcome-msg-wrapper">
                    <p class="welcome-msg" style="opacity: 1; transform: translateY(0);">自作ゲーム・ツール一覧</p>
                </div>
                <p style="color: #7d6b70; margin-top: 10px; font-size: 1rem;">よくぞおいでなすった ゆっくりしていくがよい🍵</p>
            </div>

            <!-- ゲームカードのグリッドリスト -->
            <div class="games-grid">
                {gameList.map((game) => (
                    <a href={game.href} class="game-card">
                        <div>
                            <div class="game-card-header">
                                <div class="game-icon">{game.icon}</div>
                                <h3 class="game-title">{game.title}</h3>
                            </div>
                            <p class="game-desc">{game.desc}</p>
                        </div>
                        <span class="game-link-text">プレイする →</span>
                    </a>
                ))}
            </div>

        </div>
    </main>

    <!-- 共通フッター -->
    <Footer />

</body>
</html>